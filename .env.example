# ============================================
# AMD Hackathon - Hybrid Routing Agent Config
# ============================================

# --- Fireworks AI (Remote Model) ---
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_TEMPERATURE=0.1
FIREWORKS_MAX_TOKENS=512

# --- Local Model ---
LOCAL_MODEL_NAME=google/gemma-2-2b-it
LOCAL_MODEL_DEVICE=auto
LOCAL_MODEL_MAX_NEW_TOKENS=512
LOCAL_MODEL_TEMPERATURE=0.1
LOCAL_MODEL_DTYPE=auto

# --- Router Thresholds ---
# Complexity score above this → route to remote (0.0 - 1.0)
ROUTER_COMPLEXITY_THRESHOLD=0.6
# If local model confidence below this → fallback to remote (0.0 - 1.0)
ROUTER_CONFIDENCE_FALLBACK_THRESHOLD=0.2

# --- Optimizations ---
# Enable response caching (true/false)
CACHE_ENABLED=true
# Enable prompt compression for remote calls (true/false)
COMPRESSION_ENABLED=true

# --- General ---
LOG_LEVEL=INFO
